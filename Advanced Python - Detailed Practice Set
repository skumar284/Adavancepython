#20.0. Build mini project: 
STUDENT MANAGEMENT SYSTEM 
Features: - Add student - View student - Delete student - Store data in file or database 

import csv
import os
FILE_NAME = "students.csv"
if not os.path.exists(FILE_NAME):
    with open(FILE_NAME, "w", newline="") as file:
        writer = csv.writer(file)
        writer.writerow(["ID", "Name", "Age", "Grade"])  # header
def add_student():
    student_id = input("Enter Student ID: ")
    name = input("Enter Name: ")
    age = input("Enter Age: ")
    grade = input("Enter Grade: ")
    with open(FILE_NAME, "a", newline="") as file:
        writer = csv.writer(file)
        writer.writerow([student_id, name, age, grade])
    print(f"Student {name} added successfully!\n")
def view_students():
    print("\n--- All Students ---")
    with open(FILE_NAME, "r") as file:
        reader = csv.reader(file)
        for row in reader:
            print(row)
    print()
def delete_student():
    student_id = input("Enter the Student ID to delete: ")
    students = []

    with open(FILE_NAME, "r") as file:
        reader = csv.reader(file)
        students = list(reader)
    found = False
    with open(FILE_NAME, "w", newline="") as file:
        writer = csv.writer(file)
        for row in students:
            if row[0] != student_id:
                writer.writerow(row)
            else:
                found = True
    if found:
        print(f"Student with ID {student_id} deleted successfully!\n")
    else:
        print(f"No student found with ID {student_id}\n")
def main():
    while True:
        print("=== Student Management System ===")
        print("1. Add Student")
        print("2. View Students")
